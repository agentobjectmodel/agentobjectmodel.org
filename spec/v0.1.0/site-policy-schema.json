{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://www.agentobjectmodel.org/spec/v0.1.0/site-policy-schema.json",
    "title": "AOM Site Policy Schema v0.1.0",
    "description": "Site-wide automation policy served at /.well-known/aom-policy.json",
    "type": "object",
    "required": ["automation_policy", "aom_version"],
    "properties": {
      "automation_policy": {
        "type": "string",
        "enum": ["allowed", "forbidden", "open"],
        "description": "Default automation policy for all surfaces on this domain"
      },
      "aom_version": {
        "type": "string",
        "pattern": "^0\\.\\d+\\.\\d+$",
        "description": "AOM spec version this policy targets"
      },
      "expires": {
        "type": "string",
        "format": "date-time",
        "description": "Optional expiration timestamp"
      },
      "_comment": {
        "type": "string",
        "description": "Human-readable note. Agents ignore this field."
      }
    }
  }
  